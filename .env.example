APP_NAME=FantaPortoscuso API
API_PORT=8001
DATABASE_URL=sqlite:///./data/db/app.db
KEY_LENGTH=8
AUTH_SECRET=change-me
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
BACKUP_DIR=./data/backups
BACKUP_KEEP_LAST=20
AUTO_INTERNAL_SCHEDULERS_ENABLED=1
AUTO_LIVE_IMPORT_ENABLED=1
AUTO_LIVE_IMPORT_INTERVAL_MINUTES=5
AUTO_LIVE_IMPORT_ON_START=1
AUTO_SERIEA_LIVE_SYNC_ENABLED=1
AUTO_SERIEA_LIVE_SYNC_INTERVAL_MINUTES=5
AUTO_SERIEA_LIVE_SYNC_ON_START=1
# Leghe Fantacalcio sync (optional, requires credentials)
AUTO_LEGHE_SYNC_ENABLED=0
AUTO_LEGHE_SYNC_ON_START=0
AUTO_LEGHE_SYNC_SLOT_HOURS=1
LEGHE_ALIAS=
LEGHE_USERNAME=
LEGHE_PASSWORD=
# Optional overrides:
# LEGHE_COMPETITION_ID=
# LEGHE_COMPETITION_NAME=
# LEGHE_FORMATIONS_MATCHDAY=
IMPORT_SECRET=
# Build-time frontend API base (nginx reverse proxy)
VITE_API_BASE=/api
